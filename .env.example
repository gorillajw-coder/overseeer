# Overseer 환경변수 템플릿
# 이 파일을 ~/.claude/.env 로 복사한 뒤 실제 값을 채워 넣으세요.
# (절대 실제 값이 든 .env 를 git에 커밋하지 마세요 — .gitignore로 막혀 있습니다.)

# Anthropic API 키 (요약 생성용)
ANTHROPIC_API_KEY=sk-ant-xxx

# Notion 통합(Integration) 토큰 — REST API용 (ntn_ 으로 시작)
# https://www.notion.so/my-integrations 에서 발급
NOTION_TOKEN=ntn_xxx

# Notion 데이터베이스 ID
NOTION_DB_ID=111b3e294a6b434a85835e413e78c0b9

# 커밋 링크 생성용 GitHub 레포 URL (끝에 슬래시 없이)
GITHUB_REPO_URL=https://github.com/gorillajw-coder/overseer
