# Overseer 환경변수 템플릿
# 이 파일을 ~/.claude/.env 로 복사한 뒤 실제 값을 채워 넣으세요.
# (절대 실제 값이 든 .env 를 git에 커밋하지 마세요 — .gitignore로 막혀 있습니다.)
#
# ⚠️ 여러 기기를 쓴다면 ~/.claude/.env 는 "그 서버"에서 직접 고쳐야 합니다.
#    로컬 사본을 고쳐도 서버에는 반영되지 않습니다.

# Anthropic API 키 (요약 생성용)
ANTHROPIC_API_KEY=sk-ant-xxx

# 텔레그램 (아침 다이제스트 발송 + Claudy 봇)
# 봇 토큰: @BotFather / chat_id: 봇에 메시지 보낸 뒤 getUpdates 로 확인
TELEGRAM_BOT_TOKEN=123456:xxxxx
TELEGRAM_CHAT_ID=000000000

# 이메일 (아침 다이제스트 발송, Gmail SMTP)
# SMTP_PASS 는 Gmail "앱 비밀번호"(16자 소문자). 일반 비번은 거부됨.
EMAIL_TO=you@gmail.com
SMTP_USER=you@gmail.com
SMTP_PASS=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# 커밋 링크 생성용 GitHub 레포 URL (끝에 슬래시 없이)
GITHUB_REPO_URL=https://github.com/gorillajw-coder/overseeer

# (선택) Claudy 봇 동작 조정
# CLAUDE_BIN=/home/youruser/.local/bin/claude
# CLAUDY_WORKDIR=/home/youruser/claudy-workspace
# CLAUDY_CLAUDE_ARGS=--dangerously-skip-permissions
# CLAUDY_TIMEOUT=300
